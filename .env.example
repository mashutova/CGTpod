# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional - audio backend
AUDIO_BACKEND=podcastfy          # podcastfy (default) or notebooklm
TTS_BACKEND=edge                 # edge (default, free) or openai
OPENAI_API_KEY=sk-...            # only if TTS_BACKEND=openai

# Optional - pipeline tuning
MIN_ARTICLES=3                   # min CGT articles for daily episode
LOG_LEVEL=INFO
